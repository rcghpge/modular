load("//bazel:api.bzl", "modular_py_binary", "modular_run_binary_test", "requirement")

package(default_visibility = ["//visibility:private"])

# eager_simple.py
modular_py_binary(
    name = "eager_simple",
    srcs = ["eager_simple.py"],
    imports = ["."],
    deps = [
        "//max/python/max:tensor",
        "//max/python/max/driver",
    ],
)

modular_run_binary_test(
    name = "eager_simple_test",
    size = "large",
    binary = "eager_simple",
    # FIXME: MOCO-3663 — doc example tests consistently timeout on remote macOS workers
    target_compatible_with = select({
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)

