load("//bazel:api.bzl", "modular_py_binary", "modular_run_binary_test")

package(default_visibility = ["//visibility:private"])

# arithmetic.py
modular_py_binary(
    name = "arithmetic",
    srcs = ["arithmetic.py"],
    imports = ["."],
    mojo_deps = ["//max:MOGGKernelAPI"],
    deps = [
        "//max/python/max:tensor",
    ],
)

modular_run_binary_test(
    name = "arithmetic_test",
    size = "large",
    binary = "arithmetic",
)

# tensor_math_ops.py
modular_py_binary(
    name = "tensor_math_ops",
    srcs = ["tensor_math_ops.py"],
    imports = ["."],
    mojo_deps = ["//max:MOGGKernelAPI"],
    deps = [
        "//max/python/max:tensor",
    ],
)

modular_run_binary_test(
    name = "tensor_math_ops_test",
    size = "large",
    binary = "tensor_math_ops",
    # FIXME: MOCO-3605 — Metal AIR compiler doesn't support bf16 sqrt
    target_compatible_with = select({
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)

