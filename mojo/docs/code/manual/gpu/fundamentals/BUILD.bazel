load("//bazel:api.bzl", "modular_run_binary_test", "mojo_binary")

package(default_visibility = ["//oss/modular/docs:__subpackages__"])

MOJO_SRCS = glob(["*.mojo"])

# TODO(MSTDL-2569): MTLCompilerService crashes / "Compute function exceeds
# available stack space" compiling GPU kernels that call `print()` in multi-
# block grids on Apple Silicon BuildBuddy workers.
_APPLE_GPU_INCOMPATIBLE = select({
    "//:apple_gpu": ["@platforms//:incompatible"],
    "//conditions:default": [],
})

_EXTRA_CONSTRAINTS = {
    "print_threads": _APPLE_GPU_INCOMPATIBLE,
}

[
    mojo_binary(
        name = src.split(".")[0],
        srcs = [src],
        target_compatible_with = ["//:has_gpu"] + _EXTRA_CONSTRAINTS.get(
            src.split(".")[0],
            [],
        ),
        deps = [
            "@mojo//:std",
        ],
    )
    for src in MOJO_SRCS
]

[
    modular_run_binary_test(
        name = src.split(".")[0] + "_test",
        size = "small",
        binary = src.split(".")[0],
        tags = ["gpu"],
    )
    for src in MOJO_SRCS
]
