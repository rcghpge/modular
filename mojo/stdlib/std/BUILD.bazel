load("//bazel:api.bzl", "mojo_library", "pkg_files")

# gazelle:default_visibility //visibility:public

package(default_visibility = ["//visibility:public"])

exports_files(["__init__.mojo"])

filegroup(
    name = "std_srcs",
    srcs = glob(["**/*.mojo"]),
)

# Base stdlib sources excluding files that plugins may replace.
# Downstream builds can overlay the excluded files with plugin-specific
# implementations to extend device and target support.
filegroup(
    name = "std_composable_srcs",
    srcs = glob(
        ["**/*.mojo"],
        exclude = [
            "gpu/host/device_context.mojo",
            "gpu/host/info.mojo",
            "gpu/host/compile.mojo",
            "gpu/host/__init__.mojo",
            "gpu/__init__.mojo",
            "sys/info.mojo",
            "sys/__init__.mojo",
            "math/math.mojo",
            "_plugin/__init__.mojo",
            "_plugin/_impl.mojo",
        ],
    ),
    tags = ["maybe-unused"],  # Consumed by external plugin repos.
    visibility = ["//visibility:public"],
)

mojo_library(
    name = "std",
    srcs = [
        ":std_srcs",
    ],
    docs_hosted_on_mojolang = True,
    docs_title = "Mojo standard library",
    validate_missing_docs = True,
)

pkg_files(
    name = "docs",
    srcs = [":std.docs"],
    renames = {
        "std.docs": "std",
    },
)
