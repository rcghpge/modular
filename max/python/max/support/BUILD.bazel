load("//bazel:api.bzl", "modular_py_library", "requirement")

package(default_visibility = ["//max:consumers"])

modular_py_library(
    name = "support",
    srcs = glob(
        ["**/*.py"],
        exclude = ["taskgroups.py"],
    ),
    ignore_unresolved_imports = [
        "boto3",  # Optional dependency for S3 operations, available in max[benchmark]
    ],
    deps = [
        "//max/python/max:_core",
        requirement("numpy"),
    ],
)

modular_py_library(
    name = "taskgroups",
    srcs = ["taskgroups.py"],
    deps = [
        requirement("exceptiongroup"),  # only for python < 3.11
        requirement("taskgroup"),  # only for python < 3.11
    ],
)
