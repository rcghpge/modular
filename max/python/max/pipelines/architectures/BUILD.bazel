load("//bazel:api.bzl", "modular_py_library")

package(default_visibility = ["//max:consumers"])

modular_py_library(
    name = "architectures",
    srcs = glob(["*.py"]),
    ignore_extra_deps = [
        # Hooks added for convenience for when we want to print the model layers
        "//max/python/max/nn/hooks",
    ],
    ignore_unresolved_imports = [
        # Private tool parsers are imported at runtime, not directly
        "tool_parsers",
        # Private MiniMax-M3 arch is imported at runtime, not directly
        "minimax_m3",
    ],
    deps = [
        "//max/python/max/pipelines/lib",
        # Hooks added for convenience for when we want to print the model layers
        "//max/python/max/nn/hooks",
    ],
)
