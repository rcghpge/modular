load("//bazel:api.bzl", "modular_py_library")

package(default_visibility = ["//max:consumers"])

modular_py_library(
    name = "pipelines",
    srcs = [
        "__init__.py",
    ],
    deps = [
        "//max/python/max/pipelines/architectures",
        "//max/python/max/pipelines/diffusion",
        "//max/python/max/pipelines/lib",
        "//max/python/max/pipelines/lora",
        "//max/python/max/pipelines/sampling",
        "//max/python/max/pipelines/weights",
    ],
)

modular_py_library(
    name = "logging_utils",
    srcs = ["logging_utils.py"],
    deps = [
        "//max/python/max/pipelines/lib",
        "//max/python/max/pipelines/modeling",
        "//max/python/max/support",
    ],
)
