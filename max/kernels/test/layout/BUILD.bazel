load("//bazel:api.bzl", "lit_tests", "mojo_filecheck_test", "mojo_test")

package(default_visibility = ["//max:consumers"])

_FILECHECK_TESTS = [
    "test_element.mojo",
    "test_layout.mojo",
    "test_swizzle.mojo",
    "test_tensor.mojo",
    "test_tensor_masked.mojo",
    "test_tensor_math.mojo",
    "test_tensor_runtime_layout.mojo",
    "test_tiled_matmul.mojo",
    "test_vectorized_matmul.mojo",
]

_LIT_TESTS = [
    "test_tile_tensor_copy_from_mismatched_element_size_fail.mojo",
    "test_tile_tensor_copy_from_mismatched_total_elements_fail.mojo",
    "test_tile_tensor_split_static_non_divisible_fail.mojo",
]

_EXTRA_CONSTRAINTS = {
    "test_tensor_masked.mojo": select({
        "//:asan": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
}

[
    mojo_filecheck_test(
        name = src + ".test",
        srcs = [src],
        target_compatible_with = _EXTRA_CONSTRAINTS.get(src, []),
        deps = [
            "//max:layout",
            "@mojo//:std",
            "@mojo//:test_utils",
        ],
    )
    for src in _FILECHECK_TESTS
]

mojo_filecheck_test(
    name = "test_negative_index_int_tuple.mojo.test",
    srcs = ["test_negative_index_int_tuple.mojo"],
    expect_crash = True,
    deps = [
        "//max:layout",
        "@mojo//:std",
    ],
)

mojo_filecheck_test(
    name = "test_tile_tensor_split_dynamic_negative_idx.mojo.test",
    srcs = ["test_tile_tensor_split_dynamic_negative_idx.mojo"],
    expect_crash = True,
    deps = [
        "//max:layout",
        "@mojo//:std",
    ],
)

[
    mojo_test(
        name = src + ".test",
        srcs = [src],
        deps = [
            "//max:layout",
            "@mojo//:std",
            "@mojo//:test_utils",
        ],
    )
    for src in glob(
        ["**/*.mojo"],
        exclude = _FILECHECK_TESTS + _LIT_TESTS + [
            "test_negative_index_int_tuple.mojo",
            "test_tile_tensor_split_dynamic_negative_idx.mojo",
        ],
    )
]

lit_tests(
    name = "lit",
    size = "small",
    srcs = _LIT_TESTS,
    mojo_deps = [
        "//max:layout",
        "@mojo//:std",
    ],
)
