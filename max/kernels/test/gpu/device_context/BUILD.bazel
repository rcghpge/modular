load("//bazel:api.bzl", "mojo_filecheck_test", "mojo_test")

package(default_visibility = ["//max:consumers"])

_APPLE_GPU_INCOMPATIBLE = select({
    "//:apple_gpu": ["@platforms//:incompatible"],
    "//conditions:default": [],
})

_EXTRA_MOJO_TEST_CONSTRAINTS = {
    "test_dump_sass.mojo": ["//:nvidia_gpu"],
    "test_function_attributes.mojo": _APPLE_GPU_INCOMPATIBLE,
    "test_external_stream.mojo": _APPLE_GPU_INCOMPATIBLE,  # Metal does not support external streams
    "test_device_stream.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: GEX-2554
    "test_device_event.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: GEX-2555
    "test_occupancy_max_active_blocks.mojo": _APPLE_GPU_INCOMPATIBLE,  # occupancy query not implemented for Metal
    "test_device_context_sub_buffer.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: GEX-2562
    "test_device_graph_builder.mojo": _APPLE_GPU_INCOMPATIBLE,  # Metal does not support device graph builder
}

[
    mojo_test(
        name = src + ".test",
        size = "large",
        srcs = [src],
        tags = ["gpu"],
        target_compatible_with = ["//:has_gpu"] + _EXTRA_MOJO_TEST_CONSTRAINTS.get(src, []),
        deps = [
            "//max:internal_utils",
            "//max:kv_cache",
            "//max:linalg",
            "//max:nn",
            "//max:quantization",
            "@mojo//:std",
        ],
    )
    for src in glob(
        ["**/*.mojo"],
        exclude = [
            "test_device_context_hal.mojo",
            "test_device_external_function.mojo",
            "test_function_error.mojo",
            "test_function_error_sync_mode.mojo",
        ],
    )
]

# Tests for the HAL-backed `DeviceContext` require the appropriate neo-driver
# plugin to be available.
mojo_test(
    name = "test_device_context_hal.mojo.test",
    size = "large",
    srcs = ["test_device_context_hal.mojo"],
    data = select({
        "//:nvidia_gpu": ["//Target:CUDAPlugin.so"],
        "//:apple_gpu": ["//Target:MetalPlugin.so"],
        "//:amd_gpu": ["//Target:HIPPlugin.so"],
        "//conditions:default": [],
    }),
    env = select({
        "//:nvidia_gpu": {
            "MODULAR_DRIVER_PLUGINS": "CUDA@$(rootpath //Target:CUDAPlugin.so)",
        },
        "//:apple_gpu": {
            "MODULAR_DRIVER_PLUGINS": "Metal@$(rootpath //Target:MetalPlugin.so)",
        },
        "//:amd_gpu": {
            "MODULAR_DRIVER_PLUGINS": "HIP@$(rootpath //Target:HIPPlugin.so)",
        },
        "//conditions:default": {},
    }),
    tags = ["gpu"],
    target_compatible_with = ["//:has_gpu"] + select({
        "//:nvidia_gpu": [],
        "//:apple_gpu": [],
        "//:amd_gpu": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }) + select({
        # TODO(KERN-2927): Hangs >1h on macOS BuildBuddy workers then SIGSEGV's
        # remote-exec. Likely Metal HAL driver issue. Re-enable when fixed.
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = [
        "//max:internal_utils",
        "//max:kv_cache",
        "//max:linalg",
        "//max:nn",
        "//max:quantization",
        "@mojo//:std",
    ],
)

filegroup(
    name = "vec_add_cubin_sm80",
    testonly = True,
    srcs = ["data/vec_add.sm80.cubin"],
)

filegroup(
    name = "vec_add_cubin_sm90",
    testonly = True,
    srcs = ["data/vec_add.sm90.cubin"],
)

filegroup(
    name = "vec_add_cubin_sm100",
    testonly = True,
    srcs = ["data/vec_add.sm100.cubin"],
)

mojo_test(
    name = "test_device_external_function.mojo.test",
    srcs = ["test_device_external_function.mojo"],
    data = select({
        "//:b200_gpu": [":vec_add_cubin_sm100"],
        "//:h100_gpu": [":vec_add_cubin_sm90"],
        "//conditions:default": [":vec_add_cubin_sm80"],
    }),
    env = select({
        "//:b200_gpu": {"CUBIN_PATH": "$(location :vec_add_cubin_sm100)"},
        "//:h100_gpu": {"CUBIN_PATH": "$(location :vec_add_cubin_sm90)"},
        "//conditions:default": {"CUBIN_PATH": "$(location :vec_add_cubin_sm80)"},
    }),
    tags = ["gpu"],
    target_compatible_with = [
        "//:has_gpu",
        "//:nvidia_gpu",
    ],
    deps = [
        "@mojo//:std",
    ],
)

mojo_filecheck_test(
    name = "test_function_error.mojo.test",
    srcs = ["test_function_error.mojo"],
    expect_crash = True,
    tags = ["gpu"],
    target_compatible_with = ["//:nvidia_gpu"] + select({
        "//:b200_gpu": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = [
        "//max:internal_utils",
        "//max:kv_cache",
        "//max:linalg",
        "//max:nn",
        "//max:quantization",
        "@mojo//:std",
    ],
)

mojo_filecheck_test(
    name = "test_function_error_sync_mode.mojo.test",
    srcs = ["test_function_error_sync_mode.mojo"],
    env = {
        "MODULAR_DEBUG": "device-sync-mode",
    },
    expect_crash = True,
    tags = ["gpu"],
    # B200 does not propagate the CUDA error through `synchronize()` even
    # with sync mode; the abort fires at DeviceContext destruction so the
    # except block never runs.
    target_compatible_with = ["//:nvidia_gpu"] + select({
        "//:b200_gpu": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = [
        "//max:internal_utils",
        "//max:kv_cache",
        "//max:linalg",
        "//max:nn",
        "//max:quantization",
        "@mojo//:std",
    ],
)
