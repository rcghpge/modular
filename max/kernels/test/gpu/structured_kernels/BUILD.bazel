load("//bazel:api.bzl", "mojo_test")

package(default_visibility = ["//max:consumers"])

# Per-file constraint overrides. Default is `//:has_gpu` + `//:amd_gpu`
# (any AMD GPU); HKMhaPrefill kernels target gfx950-specific MFMA
# intrinsics and need the mi355x constraint.
_EXTRA_CONSTRAINTS = {
    "test_hk_mha_prefill.mojo": ["//:mi355_gpu"],
    "test_hk_mha_prefill_causal.mojo": ["//:mi355_gpu"],
    "test_hk_mha_prefill_paged.mojo": ["//:mi355_gpu"],
    "test_hk_mha_prefill_gqa.mojo": ["//:mi355_gpu"],
    "test_hk_mha_prefill_rescale.mojo": ["//:mi355_gpu"],
    "test_sub_tile_loader_lds_smoke.mojo": [
        "//:has_gpu",
        "//:amd_gpu",
    ],
}

[
    mojo_test(
        name = src + ".test",
        size = "medium",
        srcs = [src],
        tags = ["gpu"],
        target_compatible_with = _EXTRA_CONSTRAINTS.get(
            src,
            [
                "//:has_gpu",
                "//:amd_gpu",
            ],
        ),
        deps = [
            "//max:layout",
            "//max:nn",
            "//max:structured_kernels",
            "@mojo//:std",
        ],
    )
    for src in glob(["**/*.mojo"])
]
