load("//bazel:api.bzl", "mojo_test")

package(default_visibility = ["//max:consumers"])

# Per-file constraint overrides. Default is `//:has_gpu` + `//:amd_gpu`
# (any AMD GPU); MhaPrefillV2 kernels target gfx950-specific MFMA
# intrinsics and need the mi355x constraint.
_EXTRA_CONSTRAINTS = {
    "test_mha_prefill_v2.mojo": ["//:mi355_gpu"],
    "test_mha_prefill_v2_causal.mojo": ["//:mi355_gpu"],
    "test_mha_prefill_v2_paged.mojo": ["//:mi355_gpu"],
    "test_mha_prefill_v2_gqa.mojo": ["//:mi355_gpu"],
    "test_mha_prefill_v2_rescale.mojo": ["//:mi355_gpu"],
    "test_mha_i2i_repro.mojo": ["//:mi355_gpu"],
    "test_mha_i2i_random_ref.mojo": ["//:mi355_gpu"],
    "test_mla_prefill_v2.mojo": ["//:mi355_gpu"],
    "test_sub_tile_loader_lds_smoke.mojo": [
        "//:has_gpu",
        "//:amd_gpu",
    ],
}

# Per-file compile defines. The test compiles the reference-cadence /
# FP32-scores path via `-D` for THIS test only, so `mla_components.mojo`
# stays byte-identical to HEAD. (`MlaPrefillV2` is the single
# reference-exact body — no body-selector knob.)
_EXTRA_COPTS = {
    "test_mla_prefill_v2.mojo": [
        "-D",
        "fp32_scores=true",
        "-D",
        "cadence=true",
    ],
}

[
    mojo_test(
        name = src + ".test",
        size = "medium",
        srcs = [src],
        copts = _EXTRA_COPTS.get(src, []),
        tags = ["gpu"],
        target_compatible_with = _EXTRA_CONSTRAINTS.get(
            src,
            [
                "//:has_gpu",
                "//:amd_gpu",
            ],
        ),
        deps = [
            "//max:layout",
            "//max:nn",
            "//max:structured_kernels",
            "@mojo//:std",
        ],
    )
    # Excluded from this glob:
    #  - nkv8 gate harness: built via the explicit per-shape targets below
    #    (needs R3 copts + shape defines the glob cannot supply).
    #  - v227 round-trip: built as an explicit `manual` target below (kept
    #    referenced but out of CI build/run; see that target).
    for src in glob(
        ["**/*.mojo"],
        exclude = [
            "test_mla_prefill_v2_nkv8_gate.mojo",
            "test_v227_adapter_round_trip.mojo",
        ],
    )
]

# v227 round-trip: `manual` keeps it referenced (no unreferenced-file lint)
# but out of CI wildcard build/run — it fails to compile under the merged
# toolchain (comptime-type mismatch at the `load_V_frag` call). Drives the
# FP8 32x32x64 (gfx950) `ds_read_tr8_b64` V loaders directly; re-enable once
# that fix lands.
mojo_test(
    name = "test_v227_adapter_round_trip.mojo.test",
    size = "medium",
    srcs = ["test_v227_adapter_round_trip.mojo"],
    tags = [
        "gpu",
        "manual",
    ],
    target_compatible_with = ["//:mi355_gpu"],
    deps = [
        "//max:layout",
        "//max:nn",
        "//max:structured_kernels",
        "@mojo//:std",
    ],
)

# ============================================================
# MlaPrefillV2 GQA (nkv>1) grouping nkv-GATE.
#
# Validates the GQA head-remap (`kv_head_idx = head_idx // _GROUP`,
# computed in `MlaPrefillV2.run` — shared kernel setup, independent
# of the inner loop) at the dispatcher-sweep shapes. The in-tree
# `test_mla_prefill_v2.mojo` only covers num_kv_heads=1; the sweep ran
# at nkv=8 and never correctness-checked it. Copts = FP32-scores + reference
# cadence (`MlaPrefillV2` is the single reference-exact body — no
# body-selector knob). One target per (num_heads, seq) x num_kv_heads;
# each runs NullMask + Causal, gate cos_sim >= 0.997 against a meaningful
# random (randn, distinct-per-kv-head) FP32 ref.
# ============================================================
_R3_BASE_COPTS = [
    "-D",
    "fp32_scores=true",
    "-D",
    "cadence=true",
]

[
    mojo_test(
        name = "test_mla_prefill_v2_nkv8_gate_nkv{nkv}_h{nh}_s{seq}.test".format(
            nh = nh,
            nkv = nkv,
            seq = seq,
        ),
        # Per-shape timeout tier (all remaining shapes fit `large`; the
        # seq=8192 cases whose host FP32 reference overran were dropped).
        size = test_size,
        srcs = ["test_mla_prefill_v2_nkv8_gate.mojo"],
        copts = _R3_BASE_COPTS + [
            "-D",
            "num_kv_heads={}".format(nkv),
            "-D",
            "num_heads={}".format(nh),
            "-D",
            "seq_len={}".format(seq),
        ],
        # h128/s8192 device buffers (Q 201MB + O 268MB + latent + host
        # mirrors) blow the default 0.8 GiB (-0.6 adj = 205MB) GPU-memory
        # grant. The `test.resources:gpu-memory` exec_property is NOT
        # tracked by the LOCAL bazel resource manager (CI-only), so set
        # the manager byte budget directly in `env` — the rule merges
        # `env` LAST (after get_default_test_env), so it wins. Sized at
        # ~(buffers + headroom) GiB in bytes.
        env = {"MODULAR_DEVICE_CONTEXT_MEMORY_MANAGER_SIZE": mm_bytes},
        tags = ["gpu"],
        target_compatible_with = ["//:mi355_gpu"],
        deps = [
            "//max:layout",
            "//max:nn",
            "//max:structured_kernels",
            "@mojo//:std",
        ],
    )
    for (nkv, nh, seq, mm_bytes, test_size) in [
        # nkv=8 GQA grouping (the un-validated sweep path). The GQA
        # head-remap (`kv_head_idx = head_idx // _GROUP`) is computed in
        # kernel setup and is seq-independent, so seq in {512, 2048}
        # exercises every (num_heads, nkv) grouping. The seq=8192 cases
        # are omitted: their O(num_heads * seq^2 * d) host FP32 reference
        # exceeds the CI test timeout without adding grouping coverage.
        # mm_bytes: device-memory-manager budget in bytes.
        (8, 16, 512, "2147483648", "large"),  # 2 GiB
        (8, 16, 2048, "2147483648", "large"),
        (8, 32, 512, "2147483648", "large"),
        (8, 32, 2048, "2147483648", "large"),
        (8, 128, 512, "2147483648", "large"),
        (8, 128, 2048, "4294967296", "large"),
        # nkv=1 MLA-native sanity (proves the harness reproduces the
        # known-good baseline; the grouping divmod collapses to a no-op).
        (1, 32, 2048, "2147483648", "large"),
        (1, 128, 2048, "4294967296", "large"),
    ]
]
