        },
        tags = ["gpu"] + (
            ["manual"] if src in [
                "test_multistage_gemm_fp8.mojo",  # TODO: KERN-1480 Fix and remove this tag
                "test_ping_pong_shapes.mojo",  # TODO: KERN-2631 Flaky on AMD, re-enable
