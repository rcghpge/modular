        ),
        target_compatible_with = ["//:has_gpu"] + _EXTRA_CONSTRAINTS.get(src, []),
        deps = [
            "//max:internal_utils",
            "//max:linalg",
            "//max:structured_kernels",
            "@mojo//:std",
            "@mojo//:test_utils",
