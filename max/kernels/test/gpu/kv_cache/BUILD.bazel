[
    mojo_test(
        name = "test_batch_kv_cache_flash_attention_causal_mask_ragged_paged_ps{}_hs{}{}.mojo.test".format(
            page_size,
            head_size,
            "_pair_cta" if pair_cta else "",
        ),
        size = "large",
        srcs = [
            "kv_cache_test_utils.mojo",
            "test_batch_kv_cache_flash_attention_causal_mask_ragged_paged.mojo",
        ],
        copts = [
            "-D",
            "page_size={}".format(page_size),
            "-D",
            "head_size={}".format(head_size),
        ] + ([
            "-D",
            "ENABLE_MHA_PREFILL_PAIR_CTA=True",
        ] if pair_cta else []),
        enable_assertions = select({
            "//:b200_gpu": True,
            "//conditions:default": False,  # KERN-2339
        }),
        exec_properties = {
            "test.resources:gpu-memory": "5",
        },
        main = "test_batch_kv_cache_flash_attention_causal_mask_ragged_paged.mojo",
        tags = ["gpu"],
        target_compatible_with = ["//:has_gpu"] + constraints,
        deps = [
            "//max:internal_utils",
            "//max:kv_cache",
            "//max:linalg",
            "//max:nn",
            "//max:quantization",
            "@mojo//:std",
        ],
    )
    for page_size, head_size, pair_cta, constraints in _PAGED_FA_CONFIGS
]

