load("//bazel:api.bzl", "mojo_test")

package(default_visibility = ["//max:consumers"])

_GPU_MEMORY = {
    "test_batch_kv_cache_flash_attention_causal_mask_ragged.mojo": "8",
}

_APPLE_GPU_INCOMPATIBLE = select({
    "//:apple_gpu": ["@platforms//:incompatible"],
    "//conditions:default": [],
})

_EXTRA_CONSTRAINTS = {
    "test_batch_kv_cache_flash_attention.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: PRDT-506
    "test_kv_cache_matmul.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: PRDT-506
    "test_kv_cache_ragged_matmul.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: PRDT-506
    "test_batch_kv_cache_flash_attention_causal_mask.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: PRDT-506
    "test_kv_cache_ragged_matmul_scale.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: KERN-2318
    "test_kv_cache_radd.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: MOCO-3187
    "test_batch_kv_cache_flash_attention_causal_mask_ragged_paged.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: MOCO-3187
    "test_kv_cache_store_ragged.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: MOCO-3187
    "test_kv_cache_2m_iadd.mojo": _APPLE_GPU_INCOMPATIBLE,  # FIXME: MOCO-3187
    "test_mha_gemma4_sink_repro.mojo": ["//:amd_gpu"],  # gfx950 AGPR-Copy-MFMA regression check
    "test_mha_gemma4_shapes.mojo": ["//:amd_gpu"],  # gfx950 gemma4 prefill/decode regression check
}

[
    mojo_test(
        name = src + ".test",
        size = "large",
        srcs = [
            src,
            "kv_cache_test_utils.mojo",
        ],
        # KERN-2339: Several tests disabled due to bounds check failures
        enable_assertions = select({
            "//:b200_gpu": True,
            "//conditions:default": src not in [
                "test_kv_cache_matmul.mojo",  # MSTDL-2240: stack frame size exceeds limit with assertions
                "test_kv_cache_ragged_matmul.mojo",  # MSTDL-1147: fails with asserts on H100/AMD
                "test_mha_mixed_ce_tg.mojo",  # KERN-2339: accessing idx=4 in dimension of size 4
                "test_batch_kv_cache_flash_attention_causal_mask_ragged.mojo",  # KERN-2339: bounds check reveals flash attention kernel bug
                "test_batch_kv_cache_flash_attention_causal_mask_ragged_paged.mojo",  # KERN-2339: bounds check reveals flash attention kernel bug
                "test_batch_kv_cache_flash_attention.mojo",  # KERN-2339: bounds check reveals flash attention kernel bug
                "test_batch_kv_cache_flash_attention_causal_mask.mojo",  # KERN-2339: bounds check reveals flash attention kernel bug
                "test_mha_gemma4_sink_repro.mojo",  # gfx950: ASSERT=all inflates VGPR pressure enough to re-trip the AGPR-Copy-MFMA pass that this test reproduces (commit 0da7baf2baf already chunks the K reg tile down to BK)
                "test_mha_gemma4_shapes.mojo",  # gfx950: ASSERT=all inflates VGPR pressure enough to cause register spills that mask the prefill/decode regression this test checks for (commit 0da7baf2baf already chunks the K reg tile down to BK)
            ],
        }),
        exec_properties = {
            "test.resources:gpu-memory": _GPU_MEMORY.get(src, "5"),
        },
        main = src,
        tags = ["gpu"],
        target_compatible_with = ["//:has_gpu"] + _EXTRA_CONSTRAINTS.get(src, []),
        deps = [
            "//max:internal_utils",
            "//max:kv_cache",
            "//max:linalg",
            "//max:nn",
            "//max:quantization",
            "@mojo//:std",
        ],
    )
    for src in glob(
        ["**/*.mojo"],
        exclude = [
            "kv_cache_test_utils.mojo",  # Imported source, not a test
            "test_mha_inflight_batching_gemma3_hang.mojo",  # KERN-2734: manual repro test
            "test_batch_kv_cache_flash_attention_causal_mask_ragged_paged.mojo",  # Split by page_size below
        ],
    )
]

# test_batch_kv_cache_flash_attention_causal_mask_ragged_paged.mojo
# split by (page_size, head_size, pair_cta) via -D defines.
# One row per test target; constraints are pre-composed.
#
# page_size:
#   256: default, all GPUs (except Apple).
#   64:  sub-tile paged loads, B200 only.
#
# head_size:
#   64, 128: all GPUs (subject to page_size).
#   256:     depth512 kernel, H100 and B200 only.
#   512:     depth512 kernel, B200 only.
#
# pair_cta=True sets -D ENABLE_MHA_PREFILL_PAIR_CTA=True, the SM100 FA4
# prefill optimization for 64 < depth <= 128 (see
# max/kernels/src/nn/attention/gpu/mha.mojo). B200 only. Only
# head_size=128 is meaningful; other head sizes bypass the code path.
_PAGED_FA_CONFIGS = [
    # (page_size, head_size, pair_cta, extra_constraints)
    ("256", "64", False, _APPLE_GPU_INCOMPATIBLE),
    ("256", "128", False, _APPLE_GPU_INCOMPATIBLE),
    (
        "256",
        "256",
        False,
        select({
            "//:h100_gpu": [],
            "//:b200_gpu": [],
            "//conditions:default": ["@platforms//:incompatible"],
        }),
    ),
    (
