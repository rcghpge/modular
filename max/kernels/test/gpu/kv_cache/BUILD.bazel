# test_mha_gemma4_shapes.mojo
# split by (page_size, mask_kind) via -D defines.
#
# AMD-only "amd_repro" target (page_size=256, mask_kind=causal): preserves
# the gfx950 prefill/decode register-pressure crash regression. Assertions
# stay disabled there because ASSERT=all inflates VGPR pressure enough to
# mask the regression that commit 0da7baf2baf chunks K register tiles to
# avoid (see _AMD_ONLY_TESTS comment above).
#
# B200 targets (rest): page_size in {64, 128, 256} x mask_kind in
# {0=causal, 1=sliding_1024} drive a paged-LUT NaN regression sweep that
# reproduces KERN-2861 (CUDA_ERROR_ILLEGAL_ADDRESS / NaN at page_size=128
# on Gemma-4 production shapes). Sliding-window=1024 matches Gemma-4's
# `sliding_window` per testdata config.
_GEMMA4_SHAPES_B200_ONLY = select({
    "//:b200_gpu": [],
    "//conditions:default": ["@platforms//:incompatible"],
})

_GEMMA4_SHAPES_CONFIGS = [
    # (suffix, page_size, mask_kind, target_compatible_with, enable_assertions)
    (
        "amd_repro",
        "256",
        "0",
        ["//:amd_gpu"],
        False,
    ),
    ("ps64_causal", "64", "0", _GEMMA4_SHAPES_B200_ONLY, True),
    ("ps64_sliding_1024", "64", "1", _GEMMA4_SHAPES_B200_ONLY, True),
    ("ps128_causal", "128", "0", _GEMMA4_SHAPES_B200_ONLY, True),
    ("ps128_sliding_1024", "128", "1", _GEMMA4_SHAPES_B200_ONLY, True),
    ("ps256_causal", "256", "0", _GEMMA4_SHAPES_B200_ONLY, True),
    ("ps256_sliding_1024", "256", "1", _GEMMA4_SHAPES_B200_ONLY, True),
]

[
    mojo_test(
        name = "test_mha_gemma4_shapes_{}.mojo.test".format(suffix),
        size = "large",
        srcs = [
            "kv_cache_test_utils.mojo",
            "test_mha_gemma4_shapes.mojo",
        ],
        copts = [
            "-D",
            "page_size={}".format(page_size),
            "-D",
            "mask_kind={}".format(mask_kind),
        ],
        enable_assertions = enable_assertions,
        exec_properties = {
            "test.resources:gpu-memory": "5",
        },
        main = "test_mha_gemma4_shapes.mojo",
        tags = ["gpu"],
        target_compatible_with = ["//:has_gpu"] + constraints,
        deps = [
            "//max:internal_utils",
            "//max:kv_cache",
            "//max:linalg",
            "//max:nn",
            "//max:quantization",
            "@mojo//:std",
        ],
    )
    for suffix, page_size, mask_kind, constraints, enable_assertions in _GEMMA4_SHAPES_CONFIGS
]

