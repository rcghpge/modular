    # test_mha_gemma4_shapes.mojo is split into per-(page_size, mask_kind) targets below; the AMD-only crash repro is one of them.
}

[
    mojo_test(
        name = src + ".test",
        size = "large",
        srcs = [
            src,
            "kv_cache_test_utils.mojo",
        ],
        # KERN-2339: Several tests disabled due to bounds check failures
        enable_assertions = select({
            "//:b200_gpu": True,
            "//conditions:default": src not in [
                "test_kv_cache_matmul.mojo",  # MSTDL-2240: stack frame size exceeds limit with assertions
                "test_kv_cache_ragged_matmul.mojo",  # MSTDL-1147: fails with asserts on H100/AMD
                "test_mha_mixed_ce_tg.mojo",  # KERN-2339: accessing idx=4 in dimension of size 4
                "test_batch_kv_cache_flash_attention_causal_mask_ragged.mojo",  # KERN-2339: bounds check reveals flash attention kernel bug
                "test_batch_kv_cache_flash_attention_causal_mask_ragged_paged.mojo",  # KERN-2339: bounds check reveals flash attention kernel bug
                "test_batch_kv_cache_flash_attention.mojo",  # KERN-2339: bounds check reveals flash attention kernel bug
                "test_batch_kv_cache_flash_attention_causal_mask.mojo",  # KERN-2339: bounds check reveals flash attention kernel bug
                "test_mha_gemma4_sink_repro.mojo",  # gfx950: ASSERT=all inflates VGPR pressure enough to re-trip the AGPR-Copy-MFMA pass that this test reproduces (commit 0da7baf2baf already chunks the K reg tile down to BK)
                # test_mha_gemma4_shapes.mojo: split into per-(page_size, mask_kind) targets below; assertions handled per-target.
            ],
        }),
        exec_properties = {
            "test.resources:gpu-memory": _GPU_MEMORY.get(src, "5"),
        },
        main = src,
        tags = ["gpu"],
        target_compatible_with = ["//:has_gpu"] + _EXTRA_CONSTRAINTS.get(src, []),
        deps = [
            "//max:internal_utils",
            "//max:kv_cache",
            "//max:linalg",
            "//max:nn",
            "//max:quantization",
            "@mojo//:std",
        ],
    )
    for src in glob(
        ["**/*.mojo"],
        exclude = [
            "kv_cache_test_utils.mojo",  # Imported source, not a test
            "test_mha_inflight_batching_gemma3_hang.mojo",  # KERN-2734: manual repro test, split by page_size below
            "test_batch_kv_cache_flash_attention_causal_mask_ragged_paged.mojo",  # Split by page_size below
            "test_mha_gemma4_shapes.mojo",  # Split by (page_size, mask_kind) below
            "test_paged_lut_load_boundary.mojo",  # Split by page_size below (B200 LUT-load OOB regression)
            "test_mha_paged_kv_oob_canary.mojo",  # Split by page_size below (B200 NaN canary)
        ],
    )
]

