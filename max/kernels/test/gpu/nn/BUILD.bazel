_FILECHECK_TESTS = [
    "test_mha_tile_scheduler.mojo",
    "test_padding_gpu.mojo",
    "test_gather.mojo",
    "test_gather_nd_oob.mojo",
]

[
    mojo_filecheck_test(
        name = src + ".test",
        size = "large",
        srcs = [src],
        expect_crash = src == "test_gather_nd_oob.mojo",
        tags = ["gpu"],
        target_compatible_with = ["//:has_gpu"] + _EXTRA_CONSTRAINTS.get(src, []),
        deps = [
            "//max:internal_utils",
            "//max:linalg",
            "//max:nn",
            "//max:testdata",
            "@mojo//:std",
        ],
    )
    for src in _FILECHECK_TESTS
]

[
    mojo_test(
        name = src + ".test",
        size = "large",
        srcs = [src],
        copts = [],
        # KERN-2339: Several tests disabled due to bounds check failures
        enable_assertions = select({
            "//:amd_gpu": src not in [
                "test_flash_attention.mojo",  # MSTDL-2240: stack frame size exceeds limit with assertions
                "test_flash_attention_amd.mojo",  # MSTDL-2240: stack frame size exceeds limit with assertions
            ],
            # KERN-2339: H100 MLA kernel has OOB in LayoutTensor masking
            # infrastructure on boundary tiles (num_keys not aligned to BN).
            # The H100 path uses a different code path (mla.mojo) where the
            # OOB is in the multistage-MMA / async-copy masked tile handling.
            # The OOB is functionally benign (masked out by _kernel_mask).
            "//conditions:default": src not in [
                "test_mla.mojo",
                "test_mha_chunked_causal_mask.mojo",  # MSTDL-2240: stack frame size exceeds limit with assertions (amdgpu)
            ],
        }),
        exec_properties = {
            "test.resources:gpu-memory": "3",
        },
        tags = ["gpu"],
        target_compatible_with = ["//:has_gpu"] + _EXTRA_CONSTRAINTS.get(src, []),
        deps = [
            "//max:internal_utils",
            "//max:linalg",
            "//max:nn",
            "//max:testdata",
            "@mojo//:std",
        ],
    )
    for src in glob(
        ["**/*.mojo"],
        exclude = _FILECHECK_TESTS + [
            "test_mha_causal_mask.mojo",
        ],
    )
]

# test_mha_causal_mask.mojo split by depth via -D depth=N.
# Each depth gets its own target for parallel execution.
# Depths and their GPU constraints:
#   64, 128: all GPUs
#   72, 80, 96, 256: H100 and B200 only
#   512: B200 only (prefill-only support)
_MHA_CAUSAL_MASK_DEPTHS = {
    "64": [],
    "128": [],
    "72": select({
        "//:h100_gpu": [],
        "//:b200_gpu": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    "80": select({
        "//:h100_gpu": [],
        "//:b200_gpu": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    "96": select({
        "//:h100_gpu": [],
        "//:b200_gpu": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    "256": select({
        "//:h100_gpu": [],
        "//:b200_gpu": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    "512": select({
        "//:b200_gpu": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
}

[
    mojo_test(
        name = "test_mha_causal_mask_depth_{}.mojo.test".format(depth),
        size = "large",
        srcs = ["test_mha_causal_mask.mojo"],
        copts = [
            "-D",
            "depth={}".format(depth),
        ],
        exec_properties = {
            "test.resources:gpu-memory": "3",
        },
        tags = ["gpu"],
        target_compatible_with = ["//:has_gpu"] + constraints,
        deps = [
            "//max:internal_utils",
            "//max:linalg",
            "//max:nn",
            "//max:testdata",
            "@mojo//:std",
        ],
    )
    for depth, constraints in _MHA_CAUSAL_MASK_DEPTHS.items()
]
