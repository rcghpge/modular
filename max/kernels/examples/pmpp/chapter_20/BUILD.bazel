load("//bazel:api.bzl", "mojo_test")

package(default_visibility = ["//max:consumers"])

# Tests that exceed Metal threadgroup memory limits (32768 bytes).
_MACOS_INCOMPATIBLE_TESTS = [
    # FIXME(GEX-3391): Flash attention kernel requests 36864 bytes of
    # threadgroup memory, exceeding Metal's 32768 byte limit.
    "fig20_9.mojo",
]

[
    mojo_test(
        name = src.removesuffix(".mojo") + ".test",
        size = "medium",
        srcs = [src],
        tags = ["gpu"],
        target_compatible_with = ["//:has_gpu"] + (
            select({
                "@platforms//os:macos": ["@platforms//:incompatible"],
                "//conditions:default": [],
            }) if src in _MACOS_INCOMPATIBLE_TESTS else []
        ),
        deps = [
            "@mojo//:std",
        ],
    )
    for src in glob(["*.mojo"])
]
