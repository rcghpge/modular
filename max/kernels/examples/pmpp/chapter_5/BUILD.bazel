load("//bazel:api.bzl", "mojo_test")

package(default_visibility = ["//max:consumers"])

_NO_MAIN = [
    "fig5_1.mojo",
]

[
    mojo_test(
        name = src.removesuffix(".mojo") + ".test",
        size = "small",
        srcs = [src],
        tags = ["gpu"],
        target_compatible_with = ["//:has_gpu"],
        deps = [
            "@mojo//:std",
        ],
    )
    for src in glob(
        ["*.mojo"],
        exclude = _NO_MAIN,
    )
]
