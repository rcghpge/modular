    @param[in]
    execution_type [rocblas_datatype]
                   specifies the datatype of computation.

    ******************************************************************."""
    return _get_dylib_function[
        "rocblas_scal_batched_ex",
        def(
            Handle,
            Int32,
            type_of(alpha),
            DataType,
            type_of(x),
            DataType,
            Int32,
            Int32,
