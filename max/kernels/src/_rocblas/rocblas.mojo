    @param[in]
    incx      [rocblas_int]
              specifies the increment for the elements of x.

    ******************************************************************."""
    return _get_dylib_function[
        "rocblas_sscal",
        def(Handle, Int32, type_of(alpha), type_of(x), Int32) thin -> Status,
    ]()(handle, n, alpha, x, incx)


