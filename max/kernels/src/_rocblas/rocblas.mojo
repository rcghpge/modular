    handle: Handle,
    n: Int64,
    x: UnsafePointer[ComplexFloat64, _],
    incx: Int64,
    result: UnsafePointer[Float64, _],
) raises -> Status:
    return _get_dylib_function[
        "rocblas_dznrm2_64",
        def(
            Handle,
