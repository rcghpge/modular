# AllReduce benchmark: NCCL vs SGLang custom allreduce
# SGLang's custom allreduce (cross_device_reduce_1stage) is optimized for
# small message sizes (<256KB) using NVLink P2P communication.
# Moved to kbench. Please run the following:
# kbench bench_allreduce_subgraph.yaml --mpirun-np 8

modular_py_binary(
    name = "install_sglang",
    srcs = ["install_sglang.py"],
    main = "install_sglang.py",
    tags = [
        "gpu",
        "manual",
    ],
)

# AMD MHA prefill benchmark: MAX vs aiter (CK v2/v3) vs torch SDPA
# Run via: bazel run //max/kernels/benchmarks/misc/comparison:bench_amd_mha
# Or via kbench: kbench bench_amd_mha.yaml
modular_py_binary(
    name = "bench_amd_mha",
    srcs = ["bench_amd_mha.py"],
    env = {
        # aiter JIT needs a writable dir. Point to a persistent cache so
        # JIT-compiled .so files survive across runs (first run is slow).
        "AITER_JIT_DIR": "$$BUILD_WORKSPACE_DIRECTORY/.derived/aiter_jit_cache",
        # JIT compilation needs ninja + hipcc at runtime.
        "PATH": "/usr/bin:/bin:/usr/local/bin:/opt/rocm/bin",
    },
    main = "bench_amd_mha.py",
    tags = [
        "gpu",
        "manual",
        "no-mypy",
        "no-pydeps",
    ],
    target_compatible_with = ["//:amd_gpu"],
    deps = [
        ":aiter",
        requirement("pybind11"),
        requirement("torch"),
        "//max/kernels/benchmarks/autotune:bencher_utils",
        "//max/python/max/driver",
        "//max/python/max/engine",
        "//max/python/max/experimental/torch",
        "//max/python/max/graph",
        "//max/python/max/nn",
    ],
)

