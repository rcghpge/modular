load("//bazel:api.bzl", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//SDK/integration-test:__subpackages__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_test(
    name = "tests",
    size = "large",
    srcs = glob(
        ["*.py"],
        exclude = [
            "test_benchmark_datasets_functional.py",
            "test_benchmark_throughput_*.py",
        ],
    ),
    deps = [
        "//max/python/max/benchmark:benchmark_serving_lib",
        "//max/python/max/benchmark/benchmark_shared",
        requirement("numpy"),
        requirement("pillow"),
        requirement("pytest-asyncio"),
        requirement("pytest-mock"),
        requirement("pyyaml"),
        requirement("requests"),
        requirement("tqdm"),
        requirement("transformers"),
    ],
)

modular_py_test(
    name = "test_benchmark_datasets_functional",
    srcs = ["test_benchmark_datasets_functional.py"],
    tags = [
        "requires-network",
    ],
    deps = [
        "//max/python/max/benchmark/benchmark_shared",
        "//max/python/max/pipelines/lib",
        "//max/tests/integration:hf_repo_lock",
        requirement("transformers"),
    ],
)

modular_py_test(
    name = "test_benchmark_throughput_cpu",
    size = "large",
    srcs = glob(
        ["test_benchmark_throughput_*_cpu.py"],
    ),
    data = [
        "//max/python/max/benchmark:benchmark_throughput",
        "//max/python/max/benchmark:python_files",
        "//max/python/max/benchmark:yaml_files",
    ],
    env = {
        "BENCHMARK_THROUGHPUT_BINARY": "$(location //max/python/max/benchmark:benchmark_throughput)",
    },
    tags = [
        "no-sandbox",
        "requires-network",
    ],
    target_compatible_with = select({
        # TODO(MAXSERV-1036): Disabled due to timeouts on aarch64 machines, fix this
        "//:linux_aarch64": ["@platforms//:incompatible"],
        # Disabled on macOS: exceeds 600s CI timeout cap (full model inference too slow)
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = [
        "//max/python/max/pipelines/lib",
        "//max/tests/integration:hf_repo_lock",
    ],
)
