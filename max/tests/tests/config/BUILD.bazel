load("//bazel:api.bzl", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_test(
    name = "test_base_model",
    size = "small",
    srcs = ["test_base_model.py"],
    deps = [
        "//max/python/max/config",
        requirement("pydantic"),
    ],
)

modular_py_test(
    name = "test_config_file_model",
    size = "small",
    srcs = ["test_config_file_model.py"],
    deps = [
        "//max/python/max/config",
        requirement("pydantic"),
    ],
)
