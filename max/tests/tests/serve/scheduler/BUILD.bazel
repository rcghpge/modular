load("//bazel:api.bzl", "modular_py_library", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

# TODO(SERVOPT-949): Tests that timeout on macOS
_MACOS_INCOMPATIBLE_TESTS = [
    "test_paged_scheduler.py",
    "test_queue_depth_metric.py",
    "test_queues.py",
    "test_scheduler.py",
    "test_tts_scheduler.py",
]

# Normal CPU tests
[
    modular_py_test(
        name = src.split("/")[-1].split(".")[0],
        size = "large",
        srcs = [src],
        tags = [
            "no-pydeps",  # Declaring tests in a loop like this doesn't work well with pydeps
        ] + (
            ["external-exclusive"] if src in [
                "test_tts_scheduler.py",
                "test_paged_scheduler.py",
            ] else []  # Times out if run with too many other tests
        ),
        target_compatible_with = select({
            "@platforms//os:macos": ["@platforms//:incompatible"],
            "//conditions:default": [],
        }) if src in _MACOS_INCOMPATIBLE_TESTS else [],
        deps = [
            ":common",
            requirement("pytest-asyncio"),
            requirement("pytest-mock"),
        ],
    )
    for src in glob(
        ["*.py"],
        exclude = [
            "common.py",
            "conftest.py",
            "test_di.py",
            "*_gpu.py",
        ],
    )
]

# CPU test that needs UCX Transfer Engine requires an NVIDIA GPU (for libcuda)
# TODO(GEX-3817): upstream NIXL only ships a CUDA-flavor libplugin_UCX.so;
# CPU-only machines (e.g. m7i) lack libcuda so the plugin cannot load.
# Gate to NVIDIA until ucx_cpu plugin variant is shipped.
modular_py_test(
    name = "test_di",
    srcs = [
        "conftest.py",
        "test_di.py",
    ],
    # Explicit data dep so the NIXL plugin .so is in the runfiles tree and
    # conftest.py can locate it via TEST_SRCDIR/+http_archive+nixl_upstream/.
    data = [
        "@nixl_upstream//:libplugin_LIBFABRIC.so",
        "@nixl_upstream//:libplugin_UCX.so",
    ],
    gpu_constraints = ["//:nvidia_gpu"],
    imports = ["."],
    tags = [
        "external-exclusive",  # Times out if run with too many other tests
        "gpu",
        "manual",  # TODO(GEX-3817): b200 CI machines have IB misconfiguration causing UCX timeout
    ],
    target_compatible_with = [
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
    deps = [
        ":common",
        "//max/python/max/driver",
        "//max/python/max/nn",
        "//max/python/max/pipelines/context",
        "//max/python/max/pipelines/kv_cache",
        "//max/python/max/pipelines/lib",
        "//max/python/max/pipelines/modeling",
        "//max/python/max/pipelines/speculative",
        "//max/python/max/serve:scheduler_result",
        "//max/python/max/serve/scheduler",
        "//max/python/max/serve/worker_interface",
        requirement("numpy"),
    ],
)

# GPU tests

modular_py_test(
    name = "gpu_tests",
    srcs = glob(
        ["*_gpu.py"],
        exclude = ["common.py"],
    ),
    gpu_constraints = [
        "//:has_gpu",
        "//:nvidia_gpu",
    ] + select({
        "//:apple_gpu": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    tags = [
        "gpu",
    ],
    deps = [
        ":common",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/nn",
        requirement("numpy"),
    ],
)

modular_py_library(
    name = "common",
    srcs = ["common.py"],
    imports = ["../../.."],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/nn",
        "//max/python/max/pipelines/context",
        "//max/python/max/pipelines/kv_cache",
        "//max/python/max/pipelines/modeling",
        "//max/python/max/serve:queue",
        "//max/python/max/serve:scheduler_result",
        "//max/python/max/serve/scheduler",
        requirement("numpy"),
    ],
)
