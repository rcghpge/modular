load("//bazel:api.bzl", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//SDK/integration-test:__subpackages__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_test(
    name = "tests",
    size = "large",
    srcs = glob([
        "*.py",
        "pipelines/*.py",
    ]),
    data = [
        "//max/tests/tests/serve/testdata",
    ],
    env = {
        "MAX_SERVE_DISABLE_TELEMETRY": "True",
        "MAX_SERVE_TESTDATA": "max/tests/tests/serve/testdata",
    },
    imports = ["../.."],
    per_test_tags = {
        "test_reset_prefix_cache.py": ["external-exclusive"],
    },
    target_compatible_with = select({
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = [
        "//max/python/max/dtype",
        "//max/python/max/interfaces",
        "//max/python/max/pipelines/architectures",
        "//max/python/max/pipelines/core",
        "//max/python/max/pipelines/lib",
        "//max/python/max/serve",
        "//max/python/max/serve:config",
        "//max/python/max/serve:process_control",
        "//max/python/max/serve/media",
        "//max/python/max/serve/mocks",
        "//max/python/max/serve/pipelines",
        "//max/python/max/serve/router",
        "//max/python/max/serve/scheduler",
        "//max/python/max/serve/schemas",
        "//max/python/max/serve/telemetry",
        "//max/python/max/serve/worker_interface",
        requirement("async-asgi-testclient"),
        requirement("fastapi"),
        requirement("openai"),
        requirement("opentelemetry-api"),
        requirement("numpy"),
        requirement("pydantic"),
        requirement("pytest-asyncio"),
        requirement("safetensors"),
        requirement("sse-starlette"),
        requirement("taskgroup"),
        requirement("torch"),
        requirement("transformers"),
        requirement("pillow"),
    ],
)

modular_py_test(
    name = "parser_tests",
    srcs = glob(
        [
            "parser/*.py",
        ],
    ),
    data = [],
    env = {
        "MAX_SERVE_DISABLE_TELEMETRY": "True",
        "MAX_SERVE_TESTDATA": "max/tests/tests/serve/testdata",
    },
    deps = [
        "//max/python/max/interfaces",
        "//max/python/max/serve/parser",
        "//max/python/max/serve/router",
        "//max/python/max/serve/schemas",
    ],
)
