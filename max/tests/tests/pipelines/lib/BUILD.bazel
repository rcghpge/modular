load("//bazel:api.bzl", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_test(
    name = "tests",
    srcs = glob(
        ["test_*.py"],
        exclude = [
            "test_bounded_cache.py",
            "test_reasoning.py",
        ],
    ),
    ignore_extra_deps = [
        # Imported via string at runtime
        "//max/python/max/pipelines/architectures/llama3",
        "//max/python/max/pipelines/architectures/llama3_modulev3",
    ],
    imports = ["."],
    target_compatible_with = select({
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),  # FIXME: MOCO-2411
    deps = [
        "//max/python/max/_entrypoints",
        "//max/python/max/config",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/graph",
        "//max/python/max/nn",
        "//max/python/max/pipelines:logging_utils",
        "//max/python/max/pipelines/architectures/kimik2_5",
        "//max/python/max/pipelines/architectures/llama3",
        "//max/python/max/pipelines/architectures/llama3_modulev3",
        "//max/python/max/pipelines/architectures/minimax_m2",
        "//max/python/max/pipelines/context",
        "//max/python/max/pipelines/lib",
        "//max/python/max/pipelines/modeling",
        "//max/python/max/pipelines/weights",
        "//max/python/max/serve/parser",
        requirement("click"),
        requirement("numpy"),
        requirement("pydantic"),
        requirement("pytest-mock"),
        requirement("pyyaml"),
    ],
)

modular_py_test(
    name = "test_bounded_cache",
    srcs = ["test_bounded_cache.py"],
    deps = [
        "//max/python/max/pipelines/lib",
    ],
)

modular_py_test(
    name = "test_reasoning",
    srcs = ["test_reasoning.py"],
    target_compatible_with = select({
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),  # FIXME: MOCO-2411
    deps = [
        "//max/python/max/pipelines/architectures/kimik2_5",
        "//max/python/max/pipelines/architectures/minimax_m2",
        "//max/python/max/pipelines/lib",
        "//max/python/max/pipelines/modeling",
        requirement("numpy"),
        requirement("pytest-asyncio"),
    ],
)
