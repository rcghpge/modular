load("//bazel:api.bzl", "modular_multi_py_version_test", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//SDK/integration-test:__subpackages__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

_MULTI_VERSION_TEST_SRCS = [
    "test_graph.py",
]

# Uninit check e2e tests are tested separately (light deps, subprocess-based).
_UNINIT_CHECK_TESTS = [
    "test_uninit_check_e2e.py",
]

# Ops tests that are tested separately (with lighter deps than the main target).
_SEPARATELY_TESTED_OPS = [
    "ops/test_argsort.py",
    "ops/test_constant.py",
    "ops/test_custom.py",
    "ops/test_layer_norm.py",
    "ops/test_reduction.py",
    "ops/test_tile.py",
    "ops/elementwise/test_div.py",
    "ops/elementwise/test_is_nan.py",
    "ops/test_nonzero.py",
]

modular_py_test(
    name = "tests",
    size = "large",
    srcs = glob(
        ["**/*.py"],
        exclude = _MULTI_VERSION_TEST_SRCS + _SEPARATELY_TESTED_OPS + _UNINIT_CHECK_TESTS + ["uninit_check/**/*.py"],
    ),
    data = [
        "//max/tests/integration/Inputs/test_user_op",
        "//max/tests/tests/graph/testdata",
    ],
    env = {
        "CUSTOM_OPS_PATH": "$(rootpath //max/tests/integration/Inputs/test_user_op)",
        "MODULAR_PATH": ".",
        "TESTDATA_DIRECTORY": "max/tests/tests/graph/testdata",
    },
    ignore_extra_deps = [
        # Needed for loading gguf files, doesn't get pulled by default
        requirement("gguf"),
    ],
    imports = ["."],
    mojo_deps = [
        "//max/tests/integration/Inputs/test_user_op",
        "@mojo//:std",
    ],
    deps = [
        "//max/python/max:_core",
        "//max/python/max:_mlir_context",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/mlir",
        "//max/python/max/nn",
        requirement("gguf"),
        requirement("hypothesis"),
        requirement("numpy"),
        requirement("torch"),
    ],
)

# Ops tests with lighter deps (split from main target for faster builds).
modular_py_test(
    name = "ops_tests",
    srcs = _SEPARATELY_TESTED_OPS + ["conftest.py"],
    data = ["//max/tests/tests/graph/testdata"],
    env = {
        "MODULAR_PATH": ".",
        "TESTDATA_DIRECTORY": "max/tests/tests/graph/testdata",
    },
    imports = ["."],
    mojo_deps = [
        "@mojo//:std",
    ],
    target_compatible_with = select({
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),  # FIXME: MOCO-2411
    deps = [
        "//max/python/max:_mlir_context",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/experimental",
        "//max/python/max/graph",
        "//max/python/max/mlir",
        requirement("hypothesis"),
        requirement("numpy"),
        requirement("torch"),
    ],
)

modular_multi_py_version_test(
    name = "multi_version_tests",
    size = "large",
    srcs = _MULTI_VERSION_TEST_SRCS + [
        "conftest.py",
    ],
    data = ["//max/tests/tests/graph/testdata"],
    env = {"TESTDATA_DIRECTORY": "max/tests/tests/graph/testdata"},
    imports = ["."],
    deps = [
        "//max/python/max:_mlir_context",
        "//max/python/max/dtype",
        "//max/python/max/graph",
        "//max/python/max/mlir",
        requirement("hypothesis"),
        requirement("numpy"),
    ],
)

# Uninitialized memory read detection end-to-end tests.
# Subprocess-based: each test spawns a child process with/without the
# MODULAR_MAX_DEBUG_UNINITIALIZED_READ_CHECK env var to exercise the full
# pipeline.
modular_py_test(
    name = "test_uninit_check_e2e",
    srcs = _UNINIT_CHECK_TESTS,
    data = [
        "//max/tests/tests/graph/uninit_check/read_uninit_op",
    ] + glob(["uninit_check/*.py"]),
    env = {
        "MODULAR_PATH": ".",
        "UNINIT_OPS_PATH": "$(rootpath //max/tests/tests/graph/uninit_check/read_uninit_op)",
    },
    ignore_extra_deps = [
        # These deps are used by subprocess scripts in uninit_check/,
        # not directly imported by the test file.
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        requirement("numpy"),
    ],
    mojo_deps = [
        "//max:MOGGKernelAPI",
        "//max/tests/tests/graph/uninit_check/read_uninit_op",
        "@mojo//:std",
    ],
    # FIXME: GEX-3520 — max-engine crashes during shutdown on macOS
    target_compatible_with = select({
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        requirement("numpy"),
    ],
)
