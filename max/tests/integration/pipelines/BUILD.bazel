# Test for pipeline unit tests.

load("//bazel:api.bzl", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//SDK/integration-test:__subpackages__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_test(
    name = "test_model_config_subfolder",
    size = "small",
    srcs = ["test_model_config_subfolder.py"],
    tags = ["manual"],
    deps = [
        "//max/python/max/graph",
        "//max/python/max/pipelines",
        "//max/python/max/pipelines/lib",
        "//max/tests/integration/test_common:mocks",
    ],
)

