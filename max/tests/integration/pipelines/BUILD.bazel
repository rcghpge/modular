modular_py_test(
    name = "test_model_manifest_hf",
    size = "large",
    srcs = ["test_model_manifest_hf.py"],
    env_inherit = ["HF_TOKEN"],
    tags = [
        "manual",
        "no-sandbox",
        "requires-network",
        "run-in-hf-workflow",
    ],
    deps = [
        "//max/python/max/pipelines/lib",
        requirement("huggingface-hub"),
        requirement("transformers"),
    ],
)

modular_py_test(
    name = "tests",
    size = "large",
    srcs = glob(
        ["**/*.py"],
        exclude = [
            "**/*_gpu.py",
            "test_autoconfig_error_propagation.py",
            "test_device_graph_capture_release.py",
            "test_model_config_encoding_resolution.py",
            "test_model_config_subfolder.py",
            "test_pipeline_config_model_override.py",
            "test_pipeline_config_resolve.py",
            "test_structured_output_spec_decode_gpu.py",
            "test_model_manifest.py",
            "test_model_manifest_hf.py",
        ],
    ),
    tags = [
        "requires-network",  # This is needed for escaping HF sandbox.
    ],
    target_compatible_with = select({
        "@platforms//os:macos": ["@platforms//:incompatible"],  # FIXME: MOCO-2411
        "//conditions:default": [],
    }),
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/interfaces",
        "//max/python/max/nn",
        "//max/python/max/pipelines/core",
        "//max/python/max/pipelines/lib",
        "//max/python/max/support",
        "//max/tests/integration:hf_repo_lock",
        "//max/tests/integration/test_common:mocks",
        "//max/tests/integration/test_common:numerics",
        requirement("numpy"),
        requirement("transformers"),
    ],
)

