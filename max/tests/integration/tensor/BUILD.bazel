load("//bazel:api.bzl", "modular_py_library", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_library(
    name = "conftest",
    srcs = ["conftest.py"],
    imports = ["."],
    deps = [
        "//max/python/max:tensor",
        "//max/python/max/driver",
    ],
)

modular_py_test(
    name = "tests",
    size = "large",
    srcs = glob(
        ["*.py"],
        exclude = [
            "conftest.py",
            "test_cond_symbolic_dim_gpu.py",
            "test_flashinfer_fp4_gemm.py",
            "test_from_dim.py",
            "test_functional_custom_gpu.py",
            "test_philox_torch_divergence.py",
            "test_reduce_add_rmsnorm_fusion.py",
        ],
    ),
    data = [
        "//max/tests/integration/Inputs/kernel_verification_ops",
    ],
    env = {
        "MODULAR_KERNEL_VERIFICATION_OPS_PATH": "$(rootpath //max/tests/integration/Inputs/kernel_verification_ops)",
    },
    ignore_extra_deps = [
        # lazy import
        "//max/python/max/_interpreter_ops",
    ],
    imports = ["."],
    per_test_shard_count = {
        "test_functional_other.py": 10,
    },
    target_compatible_with = select({
        # Takes too long, this is mostly just testing plumbing into other code so low value.
        "//:asan": ["@platforms//:incompatible"],
        # FIXME: MOCO-2411
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = [
        ":conftest",
        "//max/python/max:tensor",
        "//max/python/max/_interpreter_ops",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/experimental",
        "//max/python/max/experimental/nn",
        "//max/python/max/graph",
        "//max/python/max/nn",
        requirement("ml-dtypes"),
        requirement("numpy"),
    ],
)

modular_py_test(
    name = "test_functional_custom_gpu",
    size = "large",
    srcs = ["test_functional_custom_gpu.py"],
    data = ["//max/tests/integration/Inputs/kernel_verification_ops"] + select({
        "//:b200_gpu": ["//max/kernels/test/gpu/device_context:vec_add_cubin_sm100"],
        "//:h100_gpu": ["//max/kernels/test/gpu/device_context:vec_add_cubin_sm90"],
        "//conditions:default": ["//max/kernels/test/gpu/device_context:vec_add_cubin_sm80"],
    }),
    env = {
        "MODULAR_KERNEL_VERIFICATION_OPS_PATH": "$(rootpath //max/tests/integration/Inputs/kernel_verification_ops)",
    } | select({
        "//:b200_gpu": {"CUBIN_PATH": "$(location //max/kernels/test/gpu/device_context:vec_add_cubin_sm100)"},
        "//:h100_gpu": {"CUBIN_PATH": "$(location //max/kernels/test/gpu/device_context:vec_add_cubin_sm90)"},
        "//conditions:default": {"CUBIN_PATH": "$(location //max/kernels/test/gpu/device_context:vec_add_cubin_sm80)"},
    }),
    imports = ["."],
    tags = ["gpu"],
    target_compatible_with = select({
        "//:asan": ["@platforms//:incompatible"],
        # FIXME: MOCO-2411
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": ["//:nvidia_gpu"],
    }),
    deps = [
        ":conftest",
        "//max/python/max:tensor",
        "//max/python/max/dtype",
        "//max/python/max/experimental/nn",
    ],
)

modular_py_test(
    name = "test_philox_torch_divergence",
    size = "small",
    srcs = ["test_philox_torch_divergence.py"],
    imports = ["."],
    target_compatible_with = select({
        "//:asan": ["@platforms//:incompatible"],
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = [
        "//max/python/max:tensor",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/experimental",
        requirement("torch"),
    ],
)

modular_py_test(
    name = "test_reduce_add_rmsnorm_fusion",
    srcs = ["test_reduce_add_rmsnorm_fusion.py"],
    gpu_constraints = ["//:b200_gpu"],
    imports = ["."],
    tags = [
        "gpu",
    ],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        requirement("ml-dtypes"),
        requirement("numpy"),
        requirement("torch"),
    ],
)

modular_py_test(
    name = "test_flashinfer_fp4_gemm",
    srcs = ["test_flashinfer_fp4_gemm.py"],
    data = ["//max/tests/integration/Inputs/flashinfer_fp4_gemm_ops"],
    env = {
        "FLASHINFER_FP4_GEMM_OPS_PATH": "$(rootpath //max/tests/integration/Inputs/flashinfer_fp4_gemm_ops)",
    },
    gpu_constraints = ["//:b200_gpu"],
    imports = ["."],
    tags = [
        "gpu",
    ],
    deps = [
        "//max/python/max:tensor",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        requirement("apache-tvm-ffi"),
        requirement("flashinfer-python"),
        requirement("ninja"),
        requirement("torch"),
    ],
)

modular_py_test(
    name = "test_cond_symbolic_dim_gpu",
    srcs = ["test_cond_symbolic_dim_gpu.py"],
    gpu_constraints = ["//:b200_gpu"],
    imports = ["."],
    tags = [
        "gpu",
        "no-mypy",
    ],
    deps = [
        "//max/python/max:tensor",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/experimental",
        "//max/python/max/experimental/nn",
        "//max/python/max/graph",
        requirement("numpy"),
    ],
)

modular_py_test(
    name = "test_from_dim",
    srcs = ["test_from_dim.py"],
    imports = ["."],
    tags = [
        "no-mypy",
    ],
    target_compatible_with = select({
        "//:asan": ["@platforms//:incompatible"],
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = [
        "//max/python/max:tensor",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/experimental",
        "//max/python/max/experimental/nn",
        "//max/python/max/graph",
        requirement("numpy"),
    ],
)
