load("//bazel:api.bzl", "modular_py_library", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//SDK/integration-test:__subpackages__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_library(
    name = "conftest",
    srcs = ["conftest.py"],
    imports = ["."],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/experimental/distributed",
    ],
)

modular_py_test(
    name = "tests",
    size = "large",
    srcs = glob(
        ["*.py"],
        exclude = [
            "conftest.py",
            "test_dtensor_gpu.py",
        ],
    ),
    args = [
        "-n",
        "auto",
    ],
    ignore_extra_deps = [
        requirement("pytest-xdist"),
    ],
    imports = ["."],
    target_compatible_with = select({
        "//:asan": ["@platforms//:incompatible"],
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = [
        ":conftest",
        "//max/python/max:tensor",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/experimental/distributed",
        "//max/python/max/graph",
        requirement("pytest-xdist"),
    ],
)

modular_py_test(
    name = "tests_multi_gpu",
    size = "enormous",
    srcs = ["test_dtensor_gpu.py"],
    gpu_constraints = ["//:has_multi_gpu"],
    imports = ["."],
    tags = ["gpu"],
    target_compatible_with = select({
        "//:asan": ["@platforms//:incompatible"],
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = [
        "//max/python/max:tensor",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/experimental/distributed",
        "//max/python/max/graph",
    ],
)
