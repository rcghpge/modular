modular_py_binary(
    name = "verify",
    testonly = True,
    srcs = ["verify.py"],
    env = {
        "PIPELINES_TESTDATA": (
            "max/tests/integration/architectures/llama3/testdata"
        ),
    },
    imports = ["."],
    deps = [
        "//max/tests/integration/test_common:distance_metrics",
        "//max/tests/integration/test_common:model_output",
        "//max/tests/integration/test_common:numpy_encoder",
        "//max/tests/integration/test_common:verify_utils",
        requirement("click"),
        requirement("numpy"),
    ],
)

modular_py_binary(
    name = "verify_pipelines",
    testonly = True,
    srcs = ["verify_pipelines.py"],
    data = [
        "//max/tests/integration/architectures/llama3/testdata",
        "@nvshmem_prebuilt//:host",
    ],
    env = {
        # PIPELINES_TESTDATA is required by the Llama3 scripts.
        "PIPELINES_TESTDATA": (
            "max/tests/integration/architectures/llama3/testdata"
        ),
        # required by models that use Expert Parallelism.
        "MODULAR_SHMEM_LIB_DIR": "../+http_archive+nvshmem_prebuilt",
    },
    deps = [
        "//max/tests/integration/tools:transformers_v4",
        "//max/tests/integration/tools:huggingface_hub_v0",
        # Don't sort the above deps, see generate_llm_logits
        ":verify",
        "//max/python/max/pipelines/lib",
        "//max/tests/integration/accuracy/logit_verification:logit_verification_config",
        "//max/tests/integration/tools:generate_llm_logits",
        "//max/tests/integration/tools:tag_filters",
        requirement("click"),
        "//max/tests/integration/test_common:evaluate",
        "//max/tests/integration/test_common:numpy_encoder",
        "//max/tests/integration/test_common:process_isolation",
        "//max/tests/integration/test_common:storage",
        "@rules_python//python/runfiles",
        requirement("numpy"),
        requirement("pillow"),
    ],
)

modular_py_test(
    #a generic test that can be used with parameters
    name = "test_verify_pipelines",
    size = "enormous",
    srcs = ["test_verify_pipelines.py"],
    data = [
        "//max/tests/integration/architectures/llama3/testdata",
        "@nvshmem_prebuilt//:host",
    ],
    env = {
        # PIPELINES_TESTDATA is required by the Llama3 scripts.
        "PIPELINES_TESTDATA": (
            "max/tests/integration/architectures/llama3/testdata"
        ),
        # required by models that use Expert Parallelism.
        "MODULAR_SHMEM_LIB_DIR": "../+http_archive+nvshmem_prebuilt",
    },
    exec_properties = {
        "test.resources:gpu-memory": "80",
    },
    gpu_constraints = ["//:has_gpu"],
    main = "test_verify_pipelines.py",
    tags = [
        "gpu",
        "manual",
        "no-sandbox",
        "requires-network",
    ],
    deps = [
        ":verify_pipelines",
        requirement("click"),
    ],
)

modular_py_test(
    name = "allenai/OLMo-1B-hf-float32",
    size = "large",
    srcs = ["test_verify_pipelines.py"],
    args = [
        "--pipeline=allenai/OLMo-1B-hf-float32",
        "--devices=cpu",
        "--override-pipeline-golden-location",
        "allenai/OLMo-1B-hf-float32:$(rootpath @torch_olmo-1b-hf_golden.tar.gz//file:downloaded)",
    ],
    data = [
        "//max/tests/integration/architectures/llama3/testdata",
        "@nvshmem_prebuilt//:host",
        "@torch_olmo-1b-hf_golden.tar.gz//file:downloaded",
    ],
    env = {
        "HF_HUB_OFFLINE": "1",  #needed to run locally
        # PIPELINES_TESTDATA is required by the Llama3 scripts.
        "PIPELINES_TESTDATA": (
            "max/tests/integration/architectures/llama3/testdata"
        ),
        # required by models that use Expert Parallelism.
        "MODULAR_SHMEM_LIB_DIR": "../+http_archive+nvshmem_prebuilt",
    },
    main = "test_verify_pipelines.py",
    tags = ["skip-external-ci"],  # Will not fix, see QUA-61
    target_compatible_with = select({
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//:asan": ["@platforms//:incompatible"],  # FIXME MODELS-1202: Disabled due to asan timeout
        "//conditions:default": [],
    }),
    deps = [
        ":verify_pipelines",
        "//max/tests/integration/tools:huggingface_hub_v0",
        "//max/tests/integration/tools:transformers_v4",
        requirement("click"),
    ],
)

