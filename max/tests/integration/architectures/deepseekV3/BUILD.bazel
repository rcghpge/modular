load("//bazel:api.bzl", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_test(
    name = "deepseekV3",
    size = "large",
    srcs = glob(
        ["*.py"],
        exclude = [
            "test_tool_parser.py",
        ],
    ),
    exec_properties = {
        "test.resources:gpu-memory": "1",
    },
    gpu_constraints = ["//:has_gpu"] + select({
        "//:apple_gpu": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),  # FIXME: MOCO-2411
    imports = ["."],
    tags = [
        "gpu",
    ],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/graph",
        "//max/python/max/nn",
        "//max/python/max/pipelines/architectures/deepseekV3",
        "//max/python/max/pipelines/architectures/deepseekV3_nextn",
        "//max/python/max/pipelines/kv_cache",
        "//max/python/max/pipelines/lib",
        requirement("numpy"),
        requirement("transformers"),
    ],
)

modular_py_test(
    name = "test_tool_parser",
    srcs = ["test_tool_parser.py"],
    deps = [
        "//max/python/max/pipelines/architectures/deepseekV3",
        "//max/python/max/pipelines/lib",
        "//max/python/max/pipelines/modeling",
        "//max/python/max/pipelines/weights",
    ],
)
