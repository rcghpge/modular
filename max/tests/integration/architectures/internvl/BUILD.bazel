# InternVL integration tests.

load(
    "//bazel:api.bzl",
    "modular_py_library",
    "modular_py_test",
    "requirement",
)

package(default_visibility = [
    "//:__pkg__",
    "//SDK/integration-test:__subpackages__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_library(
    name = "torch_utils",
    testonly = True,
    srcs = ["torch_utils.py"],
    imports = [".."],
    deps = [
        "//max/python/max/pipelines/architectures",
        "//max/tests/integration/test_common:storage",
        "//max/tests/integration/test_common:test_data",
        "//max/tests/integration/test_common:torch_utils",
        requirement("pillow"),
        requirement("torch"),
        requirement("torchvision"),
        requirement("transformers"),
    ],
)

# Unit tests that don't require GPU
modular_py_test(
    name = "unit_tests",
    size = "large",
    srcs = [
        "tests/test_embedding_merge_unit.py",
        "tests/test_embeddings_unit.py",
        "tests/test_weight_adapters.py",
    ],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/graph",
        "//max/python/max/pipelines/architectures",
        "//max/python/max/pipelines/lib",
        requirement("numpy"),
    ],
)

modular_py_library(
    name = "utils",
    testonly = True,
    srcs = glob(
        [
            "utils/*.py",
            "internvl_impl/*.py",
        ],
    ) + ["tests/__init__.py"],
    data = [
        "configs/internvl-2B.json",
        "configs/internvl-38B.json",
        "configs/internvl-8B.json",
    ],
    imports = ["."],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/nn",
        "//max/python/max/pipelines/architectures",
        requirement("numpy"),
        requirement("timm"),
        requirement("torch"),
        requirement("transformers"),
    ],
)

# Integration tests that require GPU
modular_py_test(
    name = "gpu_tests",
    size = "large",
    srcs = glob(
        [
            "tests/test_*.py",
        ],
        exclude = [
            "tests/test_embedding_merge_unit.py",
            "tests/test_embeddings_unit.py",
            "tests/test_weight_adapters.py",
            "tests/*multi_gpu*",
        ],
    ),
    env = {
        "MODULAR_TORCH_MEMORY_PERCENT": "0.5",
    },
    exec_properties = {
        "test.resources:gpu-memory": "4",
    },
    gpu_constraints = ["//:has_gpu"] + select({
        "//:apple_gpu": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),  # FIXME: MOCO-2411
    per_test_tags = {
        "tests/test_vision_model.py": ["manual"],  # MODELS-1422: Test timing out in CI
    },
    tags = [
        "gpu",
        "no-sandbox",
    ],
    deps = [
        ":utils",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/interfaces",
        "//max/python/max/nn",
        "//max/python/max/pipelines/architectures",
        "//max/python/max/pipelines/lib",
        requirement("numpy"),
        requirement("pillow"),
        requirement("pytest-asyncio"),
        requirement("pytest-mock"),
        requirement("torch"),
    ],
)

modular_py_test(
    name = "multi_gpu_tests",
    size = "large",
    srcs = glob(["tests/*multi_gpu*"]),
    env = {
        "MODULAR_TORCH_MEMORY_PERCENT": "0.5",
    },
    exec_properties = {
        "test.resources:gpu-memory": "4",
    },
    gpu_constraints = [
        "//:has_multi_gpu",
        "@platforms//:incompatible",  # FIXME: MOCO-3089
    ] + select({
        "//:apple_gpu": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),  # FIXME: MOCO-2411
    tags = [
        "gpu",
        "no-sandbox",
    ],
    deps = [
        ":utils",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/pipelines/architectures",
        requirement("numpy"),
        requirement("torch"),
    ],
)
