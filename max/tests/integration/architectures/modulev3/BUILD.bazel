# ModuleV3 build-graph integration tests.

load(
    "//bazel:api.bzl",
    "modular_py_test",
)

package(default_visibility = [
    "//:__pkg__",
    "//SDK/integration-test:__subpackages__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_test(
    name = "tests_gpu",
    size = "enormous",
    srcs = glob(
        ["test_*.py"],
    ),
    exec_properties = {
        "test.resources:gpu-memory": "2",
    },
    gpu_constraints = ["//:has_gpu"] + select({
        "//:apple_gpu": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    tags = [
        "gpu",
    ],
    deps = [
        "//max/python/max/pipelines/architectures",
        "//max/tests/integration/test_common:build_graph_helpers",
    ],
)
