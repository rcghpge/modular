load("//bazel:api.bzl", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_test(
    name = "tests",
    size = "large",
    timeout = "long",
    srcs = glob(["**/*.py"]),
    # Conv2d's FCRS filter layout is GPU-only; tests that touch the
    # encoder/decoder need a GPU.  Pure structural tests fall back to
    # CPU via the ``_REQUIRES_GPU`` ``pytest.mark.skipif`` in the test
    # file itself.
    gpu_constraints = ["//:has_gpu"] + select({
        "//:apple_gpu": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    ignore_extra_deps = [
        # Unsure why, this test slows down if this doesn't exist.
        "//max/python/max/_interpreter_ops",
    ],
    tags = ["gpu"],
    target_compatible_with = select({
        "@platforms//os:macos": ["@platforms//:incompatible"],  # FIXME: MOCO-2411
        "//:asan": ["@platforms//:incompatible"],  # Too slow under ASAN
        "//conditions:default": [],
    }),
    deps = [
        "//max/python/max/_interpreter_ops",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/experimental",
        "//max/python/max/experimental/nn",
        "//max/python/max/graph",
        "//max/python/max/pipelines/architectures/flux_modulev3",
        "//max/python/max/pipelines/lib",
        requirement("numpy"),
    ],
)
