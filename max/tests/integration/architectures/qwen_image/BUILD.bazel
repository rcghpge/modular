# QwenImage parity tests: MAX vs diffusers.

load(
    "//bazel:api.bzl",
    "modular_py_test",
    "requirement",
)

package(default_visibility = [
    "//:__pkg__",
    "//SDK/integration-test:__subpackages__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_test(
    name = "qwen_image",
    size = "large",
    srcs = glob(["**/test_*.py"]),
    data = [
        "//max/tests/integration/architectures/qwen_image/testdata",
    ],
    env = {
        "PIPELINES_TESTDATA": "max/tests/integration/architectures/qwen_image/testdata",
    },
    tags = [
        "no-sandbox",
    ],
    deps = [
        "//max/python/max/pipelines/lib",
        requirement("numpy"),
    ],
)
