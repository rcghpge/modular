load("//bazel:api.bzl", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//SDK/integration-test:__subpackages__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_test(
    name = "kimik2_5_vision",
    size = "large",
    srcs = glob(
        ["*.py"],
        exclude = [
            "test_encoder.py",  # MODELS-1411
            "test_vision_processor.py",
            "test_vision_transformer_eval.py",
        ],
    ),
    exec_properties = {
        "test.resources:gpu-memory": "4",
    },
    gpu_constraints = ["//:has_gpu"] + select({
        "//:apple_gpu": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    imports = ["."],
    tags = [
        "gpu",
    ],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/nn",
        "//max/python/max/pipelines/architectures",
        requirement("numpy"),
        requirement("torch"),
    ],
)

# MODELS-1411
modular_py_test(
    name = "test_encoder",
    srcs = [
        "conftest.py",
        "test_encoder.py",
    ],
    imports = ["."],
    tags = [
        "gpu",
        "manual",
    ],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/pipelines/architectures",
        requirement("numpy"),
        requirement("torch"),
    ],
)

modular_py_test(
    name = "test_vision_processor",
    srcs = ["test_vision_processor.py"],
    tags = [
        "manual",
        "requires-network",
    ],
    deps = [
        "//max/python/max/pipelines/architectures",
        "//max/python/max/pipelines/core",
        requirement("av"),
        requirement("numpy"),
        requirement("pillow"),
        requirement("torch"),
        requirement("transformers"),
    ],
)

modular_py_test(
    name = "test_vision_transformer_eval",
    size = "enormous",
    srcs = [
        "conftest.py",
        "test_vision_transformer_eval.py",
    ],
    env_inherit = ["HF_TOKEN"],
    gpu_constraints = ["//:has_gpu"] + select({
        "//:apple_gpu": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    imports = ["."],
    tags = [
        "gpu",
        "no-sandbox",
        "requires-network",
    ],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/nn",
        "//max/python/max/pipelines/architectures",
        "//max/tests/integration:hf_repo_lock",
        requirement("datasets"),
        requirement("huggingface-hub"),
        requirement("numpy"),
        requirement("safetensors"),
        requirement("torch"),
    ],
)
