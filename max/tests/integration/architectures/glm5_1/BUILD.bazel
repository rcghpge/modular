# GLM-5.1 (GlmMoeDsa) layer integration tests.

load(
    "//bazel:api.bzl",
    "modular_py_library",
    "modular_py_test",
    "requirement",
)

package(default_visibility = [
    "//:__pkg__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_library(
    name = "torch_reference",
    testonly = True,
    srcs = [
        "torch_reference/configuration_glm.py",
        "torch_reference/dense_mla_torch.py",
        "torch_reference/modeling_glm.py",
    ],
    ignore_unresolved_imports = [
        "flash_attn",
        "kernels-community.flash-mla",
    ],
    imports = ["."],
    tags = [
        "no-mypy",
    ],
    deps = [
        requirement("torch"),
        requirement("transformers"),
    ],
)

modular_py_test(
    name = "glm5_1",
    size = "large",
    srcs = glob(
        ["**/test_*.py"],
    ) + [
        "conftest.py",
    ],
    data = [
        "//max/tests/integration/architectures/glm5_1/testdata",
    ],
    env = {
        "PIPELINES_TESTDATA": "max/tests/integration/architectures/glm5_1/testdata",
        "MODULAR_TORCH_MEMORY_PERCENT": "0.5",
    },
    gpu_constraints = ["//:has_gpu"] + select({
        "//:apple_gpu": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    tags = [
        "gpu",
        "no-sandbox",
    ],
    deps = [
        ":torch_reference",
        "//max/python/max:_core",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/nn",
        "//max/python/max/pipelines/architectures/deepseekV3_2",
        "//max/python/max/pipelines/kv_cache",
        "//max/tests/integration/test_common:context_utils",
        "//max/tests/integration/test_common:graph_utils",
        requirement("numpy"),
        requirement("torch"),
    ],
)
