load("//bazel:api.bzl", "modular_py_library", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//SDK/integration-test:__subpackages__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_library(
    name = "mock_dkv_server",
    srcs = [
        "__init__.py",
        "mock_dkv_server.py",
    ],
    deps = [
        "//max/python/max/kv_cache/connectors/dkv",
        requirement("pyzmq"),
    ],
)

modular_py_test(
    name = "test_dkv_connector",
    srcs = ["test_dkv_connector.py"],
    imports = ["."],
    tags = [
        "no-mypy",
        "no-pydeps",
    ],
    deps = [
        ":mock_dkv_server",
        "//max/python/max/interfaces",
        "//max/python/max/kv_cache",
        "//max/python/max/pipelines/core",
        requirement("numpy"),
    ],
)
