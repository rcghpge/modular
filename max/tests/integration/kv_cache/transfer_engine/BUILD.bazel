load("//bazel:api.bzl", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//SDK/integration-test:__subpackages__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

[
    modular_py_test(
        name = src.split("/")[-1].split(".")[0],
        srcs = [src],
        imports = ["."],
        tags = [
            "no-pydeps",  # Declaring tests in a loop like this doesn't work well with pydeps
        ],
        # UCX currently only supports x86_64 linux machines
        target_compatible_with = [
            "@platforms//cpu:x86_64",
            "@platforms//os:linux",
        ],
        deps = [
            "//max/python/max:_core",
            "//max/python/max/engine",
            "//max/python/max/kv_cache",
            "//max/python/max/nn",
            requirement("numpy"),
        ],
    )
    for src in glob(
        ["*.py"],
        exclude = [
            "*_gpu.py",
            "test_read_transfer.py",
            "test_send_recv.py",
        ],
    )
]

modular_py_test(
    name = "test_send_recv",
    srcs = ["test_send_recv.py"],
    gpu_constraints = ["//:has_gpu"],
    imports = ["."],
    tags = [
        "gpu",
        "no-pydeps",
    ],
    deps = [
        "//max/python/max:_core",
        "//max/python/max/engine",
        "//max/python/max/kv_cache",
        "//max/python/max/nn",
        requirement("numpy"),
    ],
)

modular_py_test(
    name = "test_read_transfer",
    srcs = ["test_read_transfer.py"],
    imports = ["."],
    tags = [
        "no-pydeps",
    ],
    deps = [
        "//max/python/max:_core",
        "//max/python/max/engine",
        "//max/python/max/kv_cache",
        "//max/python/max/nn",
        requirement("numpy"),
    ],
)

_4X_GPU_TESTS = [
    "test_send_recv_multi_tensor_threaded_gpu.py",
    "test_send_recv_multi_tensor_multi_process_gpu.py",
    "test_send_recv_dp2_tp2_gpu.py",
]

modular_py_test(
    name = "multi-gpu-tests",
    srcs = glob(
        ["*_gpu.py"],
        exclude = _4X_GPU_TESTS,
    ),
    exec_properties = {
        "test.resources:gpu-memory": "2",
    },
    gpu_constraints = [
        "//:has_gpu",
        "//:has_multi_gpu",
        "//:nvidia_gpu",
    ],
    imports = ["."],
    tags = ["gpu"],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/kv_cache",
        requirement("numpy"),
    ],
)

modular_py_test(
    name = "4x-gpu-tests",
    srcs = _4X_GPU_TESTS,
    exec_properties = {
        "test.resources:gpu-memory": "2",
    },
    gpu_constraints = [
        "//:has_gpu",
        "//:has_multi_gpu",
        "//:nvidia_gpu",
        "//:has_4_gpus",
    ],
    imports = ["."],
    tags = ["gpu"],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/kv_cache",
        requirement("numpy"),
    ],
)
