load("//bazel:api.bzl", "modular_py_binary", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_binary(
    name = "run_cross_node",
    srcs = ["run_cross_node.py"],
    main = "run_cross_node.py",
    target_compatible_with = [
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
    deps = [],
)

modular_py_binary(
    name = "test_transfer_engine_cross_node",
    srcs = ["test_transfer_engine_cross_node.py"],
    main = "test_transfer_engine_cross_node.py",
    target_compatible_with = [
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/pipelines/kv_cache",
        requirement("msgspec"),
        requirement("numpy"),
        requirement("pyzmq"),
    ],
)

modular_py_test(
    name = "test_notification_latency",
    srcs = [
        "conftest.py",
        "test_notification_latency.py",
    ],
    # Explicit data dep so the NIXL plugin .so is in the runfiles tree and
    # conftest.py can locate it via TEST_SRCDIR/+http_archive+nixl_upstream/.
    data = [
        "@nixl_upstream//:libplugin_LIBFABRIC.so",
        "@nixl_upstream//:libplugin_UCX.so",
    ],
    # TODO(GEX-3817): upstream NIXL only ships a CUDA-flavor libplugin_UCX.so;
    # CPU-only machines (e.g. m7i) lack libcuda so the plugin cannot load, and
    # the standard b200 CI machines lack proper RDMA config for UCX IB path.
    # Mark manual until a suitable runner + ucx_cpu variant are available.
    gpu_constraints = ["//:nvidia_gpu"],
    imports = ["."],
    tags = [
        "gpu",
        "manual",
    ],
    target_compatible_with = [
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/pipelines/kv_cache",
        requirement("numpy"),
    ],
)

modular_py_test(
    name = "test_send_recv",
    srcs = [
        "conftest.py",
        "test_send_recv.py",
    ],
    # Explicit data dep so the NIXL plugin .so is in the runfiles tree and
    # conftest.py can locate it via TEST_SRCDIR/+http_archive+nixl_upstream/.
    data = [
        "@nixl_upstream//:libplugin_LIBFABRIC.so",
        "@nixl_upstream//:libplugin_UCX.so",
    ],
    # TODO(GEX-3817): upstream NIXL only ships a CUDA-flavor libplugin_UCX.so;
    # AMD (mi355) lacks libcuda so the plugin cannot load there.  Gate to NVIDIA
    # until ucx_rocm / ucx_cpu plugin variants are shipped.
    gpu_constraints = [
        "//:has_gpu",
        "//:nvidia_gpu",
    ],
    imports = ["."],
    tags = [
        "gpu",
    ],
    # UCX currently only supports linux machines
    target_compatible_with = [
        "@platforms//os:linux",
    ],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/pipelines/kv_cache",
        requirement("numpy"),
    ],
)

modular_py_test(
    name = "test_read_transfer",
    srcs = [
        "conftest.py",
        "test_read_transfer.py",
    ],
    # Explicit data dep so the NIXL plugin .so is in the runfiles tree and
    # conftest.py can locate it via TEST_SRCDIR/+http_archive+nixl_upstream/.
    data = [
        "@nixl_upstream//:libplugin_LIBFABRIC.so",
        "@nixl_upstream//:libplugin_UCX.so",
    ],
    # TODO(GEX-3817): upstream NIXL only ships a CUDA-flavor libplugin_UCX.so;
    # CPU-only machines (e.g. m7i) lack libcuda so the plugin cannot load, and
    # b200 CI machines have IB misconfiguration causing UCX transfers to
    # timeout. Mark manual until a suitable runner is available.
    gpu_constraints = ["//:nvidia_gpu"],
    imports = ["."],
    tags = [
        "gpu",
        "manual",
    ],
    # UCX currently only supports linux machines
    target_compatible_with = [
        "@platforms//os:linux",
    ],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/pipelines/kv_cache",
        requirement("numpy"),
    ],
)

