modular_py_test(
    name = "multi-gpu-tests",
    srcs = glob(
        ["*_gpu.py"],
        exclude = _4X_GPU_TESTS + _LIGHT_TRANSFER_GPU_TESTS,
    ) + ["conftest.py"],
    # Explicit data dep so the NIXL plugin .so is in the runfiles tree and
    # conftest.py can locate it via TEST_SRCDIR/+http_archive+nixl_upstream/.
    data = [
        "@nixl_upstream//:libplugin_LIBFABRIC.so",
        "@nixl_upstream//:libplugin_UCX.so",
    ],
    exec_properties = {
        "test.resources:gpu-memory": "5",
    },
    gpu_constraints = [
        "//:has_gpu",
        "//:has_multi_gpu",
        "//:nvidia_gpu",
    ],
    imports = ["."],
    per_test_tags = {
        "test_send_recv_multi_process_gpu.py": ["manual"],  # FIXME: Times out intermittently (SERVOPT-1326)
    },
    tags = ["gpu"],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/pipelines/kv_cache",
        requirement("numpy"),
    ],
)

