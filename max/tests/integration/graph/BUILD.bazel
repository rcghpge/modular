# GEX-3523 / MAXPLAT-477: this test was originally disabled because its 16
# GPU parametrizations exceeded the bulk graph target's timebox on H100.
# Re-enabled as a dedicated, sharded target so each shard fits comfortably
# under the 600s `ci-persistent --test_timeout=-1,-1,600,600` clamp.
#
# Per-case wall-clock (the `set_item*` cases are skipped on accelerators):
#   H100: median 31.4s, p99 42.6s, max 60.9s (from a 16 000-case stress run).
#   B200: median ~33s, max ~50s (from a smoke run with 16 GPU cases).
#
# Unsharded the B200 wall is ~640-650s, which trips the 600s ci-persistent
# clamp (observed `TIMEOUT in 610.0s` on postsubmit b200, build 6395).
# `shard_count = 4` splits the 16 cases roughly 4-per-shard, giving
# ~150-200s per shard with ~3x headroom.
modular_py_test(
    name = "test_advanced_indexing",
    size = "large",
    srcs = [
        "conftest.py",
        "test_advanced_indexing.py",
    ],
    gpu_constraints = ["//:has_gpu"] + select({
        "//:apple_gpu": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    shard_count = 4,
    tags = [
        "gpu",
    ],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        requirement("hypothesis"),
        requirement("numpy"),
        requirement("torch"),
    ],
)

