modular_py_test(
    name = "test_fusion_error_messages",
    size = "medium",
    srcs = ["test_fusion_error_messages.py"],
    data = [
        "//max/tests/integration/Inputs/kernel_verification_ops",
    ],
    env = {
        "MODULAR_MAX_DEBUG": "True",
        "MODULAR_DEVICE_CONTEXT_SYNC_MODE": "1",
        "MOJO_ASSERT_LEVEL": "all",
        "MODULAR_KERNEL_VERIFICATION_OPS_PATH": "$(rootpath //max/tests/integration/Inputs/kernel_verification_ops)",
    },
    gpu_constraints = ["//:has_gpu"] + select({
        "//:apple_gpu": ["@platforms//:incompatible"],
        "//:amd_gpu": ["@platforms//:incompatible"],  # ROCm aborts on GPU trap
        "//conditions:default": [],
    }),
    tags = [
        "gpu",
        "no-sandbox",
    ],
    deps = [
        ":fusion_error_scenarios",
        "//max/python/max/driver",
        "//max/python/max/engine",
        requirement("numpy"),
    ],
)

