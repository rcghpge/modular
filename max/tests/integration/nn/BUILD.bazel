load("//bazel:api.bzl", "modular_py_library", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//SDK/integration-test:__subpackages__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

modular_py_library(
    name = "shared_conv_impl",
    testonly = True,
    srcs = ["shared_conv_impl.py"],
    imports = ["."],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/nn",
        requirement("torch"),
        requirement("numpy"),
    ],
)

modular_py_library(
    name = "shared_mlp_impl",
    testonly = True,
    srcs = ["shared_mlp_impl.py"],
    imports = ["."],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/nn",
        "//max/tests/integration/test_common:graph_utils",
        requirement("torch"),
        requirement("pytest"),
    ],
)

modular_py_test(
    name = "nn_tests",
    size = "large",
    srcs = glob(
        ["*.py"],
        exclude = [
            "*_gpu.py",
            "shared_conv_impl.py",
            "shared_mlp_impl.py",
        ],
    ),
    imports = ["."],
    per_test_shard_count = {
        "test_mlp.py": 20,
        "test_conv.py": 8,
    },
    per_test_tags = {
        "test_conv.py": ["skip-external-ci"],
        "test_mlp.py": ["manual"],
    },
    target_compatible_with = select({
        "@platforms//os:macos": ["@platforms//:incompatible"],  # FIXME: MOCO-2411
        "//:asan": ["@platforms//:incompatible"],  # Too slow with ASAN
        "//conditions:default": [],
    }),
    deps = [
        ":shared_conv_impl",
        ":shared_mlp_impl",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/nn",
        "//max/python/max/nn/hooks:print_hook",
        "//max/tests/integration/graph:modular_graph_test",
        requirement("numpy"),
        requirement("torch"),
        requirement("hypothesis"),
        requirement("pytest-mock"),
    ],
)

modular_py_test(
    name = "nn_gpu_tests",
    size = "large",
    srcs = glob(
        ["*_gpu.py"],
        exclude = [
            "*_distributed_gpu.py",
            "test_conv_transpose_gpu.py",
            "test_linear_fp8_amd_gpu.py",
            "test_lora_kernels_gpu.py",
            "test_mlp_fp4_gpu.py",
            "test_moe_nvfp4_gpu.py",
            "test_sgmv_kernels_gpu.py",
        ],
    ) + ["conftest.py"],
    exec_properties = {
        "test.resources:gpu-memory": "3",
    },
    gpu_constraints = ["//:has_gpu"] + select({
        "//:apple_gpu": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),  # FIXME: MOCO-2411
    imports = ["."],
    tags = [
        "gpu",
    ],
    deps = [
        ":shared_conv_impl",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/nn",
        "//max/tests/integration/test_common:graph_utils",
        "//max/tests/integration/test_common:numerics",
        requirement("llguidance"),
        requirement("numpy"),
        requirement("torch"),
        requirement("triton"),
        requirement("hypothesis"),
    ],
)

modular_py_test(
    name = "nn_nvidia_gpu_tests",
    srcs = [
        "test_conv_transpose_gpu.py",
    ],
    gpu_constraints = ["//:nvidia_gpu"],
    imports = ["."],
    tags = [
        "gpu",
    ],
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/graph",
        "//max/python/max/nn",
        "//max/tests/integration/test_common:numerics",
        requirement("numpy"),
        requirement("torch"),
    ],
)

modular_py_test(
    name = "nn_distributed_gpu_tests",
    size = "enormous",
    srcs = glob(
        ["*_distributed_gpu.py"],
        exclude = [
